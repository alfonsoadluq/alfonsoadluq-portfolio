---
import Layout from '../layouts/Layout.astro';
import ThemeButton from '../components/ThemeButton.astro';
---

<Layout>
  <!-- 1. BACKGROUND AURA (Using translated class .cyan-aura) -->
  <div class="cyan-aura"></div>

  <!-- NAVIGATION -->
  <nav class="fixed top-0 w-full flex justify-between items-center p-6 z-50 backdrop-blur-sm bg-white/5 dark:bg-transparent">
    <div class="text-cyan font-black tracking-tighter text-xl">AA.</div>
    <ThemeButton />
  </nav>

  <!-- HERO SECTION -->
  <main class="flex flex-col items-center justify-center min-h-screen text-center px-4 pt-20">
    
    <!-- FLOATING BADGE -->
    <div class="floating">
        <span class="text-cyan font-bold tracking-[0.4em] text-[10px] md:text-xs mb-4 uppercase border border-cyan/20 bg-cyan/5 px-4 py-2 rounded-full shadow-[0_0_15px_rgba(0,193,253,0.1)]">
            &lt; Fullstack Architect /&gt;
        </span>
    </div>
    
    <!-- ANIMATED GRADIENT TEXT -->
    <h1 class="text-6xl md:text-8xl font-black animate-gradient-text tracking-tighter mt-8 pb-4">
        Design. Code. Secure.
    </h1>

    <div class="w-32 h-1 bg-gradient-to-r from-cyan via-blue to-purple my-8 rounded-full shadow-[0_0_20px_rgba(0,193,253,0.4)]"></div>

    <p class="text-text-muted font-medium tracking-[0.2em] text-sm md:text-base uppercase max-w-2xl">
        High Performance Applications • Cyber-Security • Cloud Architecture
    </p>

    <!-- NEW INTERACTIVE TEST SECTION -->
    <section class="mt-24 w-full max-w-6xl grid grid-cols-1 lg:grid-cols-3 gap-6 text-left">
        
        <!-- FEATURE CARD 1: ANALYTICS -->
        <div class="card-border-glow lg:col-span-2">
            <div class="card-content p-10 flex flex-col md:flex-row gap-8 items-center">
                <div class="flex-1">
                    <h3 class="text-white font-bold text-2xl mb-2 italic">Real-time Performance</h3>
                    <p class="text-text-muted text-sm leading-relaxed mb-6">
                        Testing the <code>card-border-glow</code> animation. This container features a rotating conic gradient that reacts to the theme change.
                    </p>
                    <div class="divider-beam mb-6"></div>
                    <div class="flex gap-4">
                        <div class="text-center">
                            <span class="block text-2xl font-black text-cyan">99%</span>
                            <span class="text-[10px] uppercase text-text-muted">Uptime</span>
                        </div>
                        <div class="w-[1px] h-10 bg-white/10"></div>
                        <div class="text-center">
                            <span class="block text-2xl font-black text-purple">0.2s</span>
                            <span class="text-[10px] uppercase text-text-muted">Latency</span>
                        </div>
                    </div>
                </div>
                <!-- Visual Element for the card -->
                <div class="relative w-32 h-32 flex items-center justify-center">
                   <div class="absolute inset-0 bg-cyan/20 blur-3xl rounded-full floating"></div>
                   <svg class="w-16 h-16 text-cyan drop-shadow-[0_0_10px_rgba(0,193,253,0.5)]" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                   </svg>
                </div>
            </div>
        </div>

        <!-- FEATURE CARD 2: SMALLER INTERACTIVE -->
        <div class="card-border-glow">
            <div class="card-content p-8 flex flex-col justify-between">
                <div>
                    <div class="w-10 h-10 rounded-lg bg-purple/20 flex items-center justify-center mb-6">
                        <div class="w-4 h-4 bg-purple rounded-full animate-pulse shadow-[0_0_10px_rgba(139,92,246,1)]"></div>
                    </div>
                    <h3 class="text-white font-bold text-xl mb-3 uppercase tracking-tight">Security First</h3>
                    <p class="text-text-muted text-xs leading-relaxed">
                        Notice how the background color of the card shifts smoothly from dark to light during the transition.
                    </p>
                </div>
                
                <button class="mt-8 group flex items-center gap-2 text-[10px] font-bold text-white uppercase tracking-widest">
                    Run Audit 
                    <span class="group-hover:translate-x-2 transition-transform duration-300 text-cyan">→</span>
                </button>
            </div>
        </div>

        <!-- FEATURE CARD 3: THEME TESTER -->
        <div class="lg:col-span-3 card-border-glow">
            <div class="card-content p-6 text-center overflow-hidden">
                <p class="text-[10px] text-text-muted uppercase tracking-[0.5em] mb-4">Directional Transition Test</p>
                <div class="flex justify-center items-center gap-12 py-4">
                    <div class="flex flex-col items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-cyan animate-bounce"></div>
                        <p class="text-[9px] text-cyan">BOTTOM UP (DARK)</p>
                    </div>
                    <div class="divider-beam w-32"></div>
                    <div class="flex flex-col items-center gap-2">
                        <div class="w-2 h-2 rounded-full bg-purple animate-bounce [animation-delay:0.2s]"></div>
                        <p class="text-[9px] text-purple">TOP DOWN (LIGHT)</p>
                    </div>
                </div>
            </div>
        </div>

    </section>

    <!-- SIMPLE FOOTER -->
    <footer class="mt-32 pb-12 flex flex-col items-center gap-4">
        <div class="divider-beam max-w-xs opacity-30"></div>
        <p class="text-text-muted text-[10px] tracking-[0.3em] uppercase">
            &copy; 2024 ALFONSO ADIEGO — CRAFTING DIGITAL EXPERIENCES
        </p>
    </footer>

  </main>
</Layout>

<style>
    /* Mobile responsive tweaks */
    @media (max-width: 640px) {
        h1 { font-size: 3rem; }
    }
</style>