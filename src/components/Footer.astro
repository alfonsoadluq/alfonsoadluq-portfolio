---
import { Picture } from "astro:assets";
import { Images } from "@assets/images";
import cv from "@assets/CV_Alfonso.pdf";

const currentYear = new Date().getFullYear();

const buttonData = [
    {
        label: "Email",
        href: "mailto:alfonsoaldev@gmail.com",
        title: "Correo electrónico",
        ariaLabel: "Correo electrónico",
        iconPath: "M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z M3 7l9 6l9 -6"
    },
    {
        label: "LinkedIn",
        href: "https://www.linkedin.com/in/alfonso-adiego-luque/",
        title: "LinkedIn",
        ariaLabel: "LinkedIn de Alfonso Adiego Luque",
        iconPath: "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z M2 9h4v12H2z M4 4a2 2 0 1 1 0 4 2 2 0 0 1 0-4z"
    },
    {
        label: "GitHub",
        href: "https://github.com/alfonsoadluq",
        title: "GitHub",
        ariaLabel: "GitHub de Alfonso Adiego Luque",
        iconPath: "M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"
    },
    {
        label: "Currículum",
        href: cv,
        fileName: "CV_Alfonso.pdf",
        title: "Currículum",
        ariaLabel: "Currículum de Alfonso Adiego Luque",
        iconPath: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8"
    }
]
---

<footer class="w-full py-12 border-t border-slate-200 dark:border-white/5 transition-colors duration-500 bg-slate-50/30 dark:bg-transparent">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-3 items-center gap-8 lg:gap-4">
        
        <!-- Logo -->
        <div class="flex items-center justify-center lg:justify-start gap-5">
            <a href="/#welcome" title="Inicio" class="hover:opacity-80 transition-all hover:scale-105 active:scale-95 outline-none">
                <Picture
                    src={Images.logos.logoAlfonso}
                    alt="Logo Alfonso Adiego"
                    width={40}
                    height={32}
                    formats={["avif", "webp"]}
                    class="w-10 h-auto transition-all duration-500"
                />
            </a>
            <div class="w-px h-4 bg-slate-300 dark:bg-white/10 hidden sm:block"></div>
        </div>
        
        <!-- Copyright y Autor -->
        <div class="flex flex-col items-center text-center justify-center">
            <span class="text-xs md:text-sm font-medium text-muted transition-colors duration-500 leading-relaxed">
                Diseñado y desarrollado por <br class="block md:hidden" />
                <span class="text-cyan font-bold">Alfonso Adiego Luque</span>
            </span>
            <span class="md:text-xs text-muted uppercase tracking-widest mt-1">
                &copy; {currentYear} · Todos los derechos reservados
            </span>
        </div>

        <!-- Iconos Sociales -->
        <div class="flex items-center justify-center lg:justify-end gap-6 lg:gap-8">
            {buttonData.map((btn) => (
                <a 
                    href={btn.href} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    title={btn.title} 
                    aria-label={btn.ariaLabel} 
                    class="text-slate-400 hover:text-cyan transition-all duration-300 active:scale-90"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d={btn.iconPath}></path>
                    </svg>
                </a>
            ))}
        </div>

    </div>
</footer>