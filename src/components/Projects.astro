---
import { Picture } from "astro:assets";
import { Images } from "@assets/images";
import LinkButton from "./LinkButton.astro";

const TAGS = {
  TAILWIND: { name: "Tailwind CSS", class: "bg-[#003159]/30 text-[#44a8b3] dark:text-[#44a8b3]", icon: Images.icons.TailWindIcon },
  LARAVEL: { name: "Laravel", class: "bg-[#FF2D20]/10 text-[#FF2D20]", icon: Images.icons.LaravelIcon },
  REACT: { name: "React", class: "bg-[#61DAFB]/10 text-[#61DAFB]", icon: Images.icons.ReactIcon },
}

const PROJECTS = [
  {
    title: "KitKeeper Refreshed",
    description: "Versión renovada del proyecto original KitKeeper de gestión de materiales tecnológicos en centros educativos. Implementación de una interfaz renovada y fluida usando React y Gsap, mejorando la experiencia del usuario.",
    link: "https://google.com", 
    github: "https://github.com/alfonsoadluq/kitkeeper-refreshed",
    image: Images.projects.KitKeeperPreview,
    tags: [TAGS.TAILWIND, TAGS.LARAVEL, TAGS.REACT]
  },
]

const isCarousel = PROJECTS.length > 1;
const DISPLAY_PROJECTS = isCarousel ? [...PROJECTS, ...PROJECTS, ...PROJECTS] : PROJECTS;
---

<section id={Astro.props.id} class="py-24 max-w-7xl mx-auto overflow-hidden relative">
    <div class="flex items-center justify-between mb-16 px-3">
        <h2 class="text-4xl font-black flex items-center gap-4 text-slate-900 dark:text-white tracking-tighter">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-cyan icon icon-tabler icons-tabler-filled icon-tabler-bulb"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M4 11a1 1 0 0 1 .117 1.993l-.117 .007h-1a1 1 0 0 1 -.117 -1.993l.117 -.007h1z" /><path d="M12 2a1 1 0 0 1 .993 .883l.007 .117v1a1 1 0 0 1 -1.993 .117l-.007 -.117v-1a1 1 0 0 1 1 -1z" /><path d="M21 11a1 1 0 0 1 .117 1.993l-.117 .007h-1a1 1 0 0 1 -.117 -1.993l.117 -.007h1z" /><path d="M4.893 4.893a1 1 0 0 1 1.32 -.083l.094 .083l.7 .7a1 1 0 0 1 -1.32 1.497l-.094 -.083l-.7 -.7a1 1 0 0 1 0 -1.414z" /><path d="M17.693 4.893a1 1 0 0 1 1.497 1.32l-.083 .094l-.7 .7a1 1 0 0 1 -1.497 -1.32l.083 -.094l.7 -.7z" /><path d="M14 18a1 1 0 0 1 1 1a3 3 0 0 1 -6 0a1 1 0 0 1 .883 -.993l.117 -.007h4z" /><path d="M12 6a6 6 0 0 1 3.6 10.8a1 1 0 0 1 -.471 .192l-.129 .008h-6a1 1 0 0 1 -.6 -.2a6 6 0 0 1 3.6 -10.8z" /></svg>
            Proyectos
        </h2>

        {isCarousel && (
            <div class="flex gap-4 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                <button id="prevBtn" class="btn-glass-neon p-4 rounded-full cursor-pointer hover:scale-110 active:scale-90 transition-all z-50">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                </button>
                <button id="nextBtn" class="btn-glass-neon p-4 rounded-full cursor-pointer hover:scale-110 active:scale-90 transition-all z-50">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </button>
            </div>
        )}
    </div>

    <div class="group relative">
        <div 
            id="carousel-track" 
            class:list={[
                "flex gap-8 pb-12 px-4 no-scrollbar",
                isCarousel ? "overflow-x-auto snap-x snap-mandatory" : "justify-center"
            ]}
        >
            {DISPLAY_PROJECTS.map((project) => (
                <div class:list={["shrink-0", isCarousel ? "w-[90vw] md:w-[950px] snap-center" : "w-full max-w-5xl"]}>
                    <!-- TARJETA: Blanca en Light, Oscura en Dark -->
                    <article class="flex flex-col space-x-0 space-y-8 group/card md:flex-row md:space-x-12 md:space-y-0 items-center bg-slate-50/80 dark:bg-[#050b18]/60 p-8 md:p-12 rounded-[3rem] border border-slate-200 dark:border-white/5 backdrop-blur-sm shadow-2xl h-full transition-colors duration-500">
                        
                        <div class="w-full md:w-1/2">
                            <div class="card-border-glow rounded-[2rem] transition-all duration-500">
                                <div class="card-content overflow-hidden rounded-[2rem] bg-white dark:bg-[#050b18] holographic-card relative aspect-video">
                                    <Picture
                                        src={project.image}
                                        alt={project.title}
                                        formats={["avif", "webp"]}
                                        widths={[400, 800]}
                                        class="object-cover w-full h-full transition duration-700 group-hover/card:scale-105"
                                    />
                                </div>
                            </div>
                        </div>

                        <div class="w-full md:w-1/2 flex flex-col">
                            <h3 class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white mb-4 drop-shadow-[0_0_10px_rgba(0,193,253,0.3)] uppercase tracking-tighter transition-colors duration-500">
                                {project.title}
                            </h3>
                            
                            <div class="flex flex-wrap gap-2 mb-6">
                                {project.tags.map((tag) => (
                                    <span class={`flex items-center gap-x-2 rounded-full text-[10px] font-bold uppercase tracking-wider py-2 px-4 border border-slate-200 dark:border-white/10 ${tag.class}`}>
                                        <Picture src={tag.icon} alt={tag.name} width={16} height={16} class="w-4 h-4 object-contain" />
                                        {tag.name}
                                    </span>
                                ))}
                            </div>

                            <p class="text-slate-600 dark:text-text-muted leading-relaxed mb-8 text-sm md:text-lg transition-colors duration-500">
                                {project.description}
                            </p>

                            <footer class="flex flex-wrap gap-4 mt-auto">
                                {project.github && (
                                    <LinkButton href={project.github}>
                                        <Picture src={Images.icons.GitHubIcon} alt="GitHub" width={20} height={20} class="w-5 h-5 invert dark:invert-0" />
                                        GitHub
                                    </LinkButton>
                                )}
                                {project.link && (
                                    <LinkButton href={project.link}>
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="dark:text-white text-slate-800"><path d="M12 5a1 1 0 0 1 0 2h-6a1 1 0 0 0 -1 1v10a1 1 0 0 0 1 1h10a1 1 0 0 0 1 -1v-6a1 1 0 0 1 2 0v6a3 3 0 0 1 -3 3h-10a3 3 0 0 1 -3 -3v-10a3 3 0 0 1 3 -3zm3 -2h5l.075 .003l.126 .017l.111 .03l.111 .044l.098 .052l.096 .067l.09 .08q .054 .053 .097 .112l.071 .11l.054 .114l.035 .105l.03 .148l.006 .118v5a1 1 0 0 1 -2 0v-2.586l-7.293 7.293a1 1 0 0 1 -1.414 -1.414l7.291 -7.293h-2.584a1 1 0 0 1 0 -2" /></svg>
                                        Pruébalo
                                    </LinkButton>
                                )}
                            </footer>
                        </div>
                    </article>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    section:hover .transition-opacity { opacity: 1; }
</style>

<script>
    /* ... se mantiene tu script de carrusel intacto ... */
    const initCarousel = () => {
        const track = document.getElementById('carousel-track');
        const nextBtn = document.getElementById('nextBtn');
        const prevBtn = document.getElementById('prevBtn');
        if (!track || !nextBtn || !prevBtn) return;
        const getItemWidth = () => track.firstElementChild.clientWidth + 32;
        const move = (direction) => { track.scrollBy({ left: direction * getItemWidth(), behavior: 'smooth' }); };
        nextBtn.addEventListener('click', () => move(1));
        prevBtn.addEventListener('click', () => move(-1));
        track.addEventListener('scroll', () => {
            const itemWidth = getItemWidth();
            const totalWidth = track.scrollWidth;
            const viewWidth = track.clientWidth;
            if (track.scrollLeft + viewWidth >= totalWidth - 10) {
                track.scrollTo({ left: track.scrollLeft - (totalWidth / 3), behavior: 'instant' });
            } else if (track.scrollLeft <= 10) {
                track.scrollTo({ left: track.scrollLeft + (totalWidth / 3), behavior: 'instant' });
            }
        });
        requestAnimationFrame(() => { track.scrollLeft = track.scrollWidth / 3; });
    }
    initCarousel();
    document.addEventListener('astro:page-load', initCarousel);
</script>