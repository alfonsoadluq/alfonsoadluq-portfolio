---
import { Picture } from "astro:assets";
import { Images } from "@assets/images";
import LinkButton from "./LinkButton.astro";

const { isFull = false } = Astro.props;

const FILTERS = [
  { id: "all", title: "Todos", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h6v6H4zm10 0h6v6h-6zM4 14h6v6H4zm10 0h6v6h-6z"/></svg>` },
  { id: "work", title: "Empresa", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>` },
  { id: "personal", title: "Personal", icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>` }
];

export const PROJECTS = [
  {
    id: "fichaje",
    category: "work",
    featured: true, 
    inDevelopment: false,
    overline: "MOBILE + FULL STACK • SAAS LABORAL",
    title: "App de Fichaje Laboral",
    description: "Desarrollé íntegramente el sistema multi-tenant: backend en Laravel y app móvil en React Native. Una solución robusta con validez legal.",
    image: Images.projects.KitKeeperPreview,
    features: ["FICHAJE CON GEOLOCALIZACIÓN", "INFORMES CON FIRMA DIGITAL", "ARQUITECTURA MULTI-TENANT"],
    skills: ["React Native", "Laravel", "MySQL"],
    actionLinks: [{ label: "Google Play", href: "#" }]
  },
  {
    id: "foody",
    category: "personal",
    featured: false, 
    inDevelopment: true,
    overline: "MOBILE • APRENDIZAJE",
    title: "Foody — Recetas",
    description: "Gestión inteligente de inventario y recetas para el hogar.",
    image: Images.projects.KitKeeperPreview, 
    features: ["AUTENTICACIÓN COMPLETA", "CÁLCULO DE CANTIDADES"],
    skills: ["React Native", "Expo", "Supabase"],
    actionLinks: []
  },
  {
    id: "slotix",
    category: "personal",
    featured: false, 
    inDevelopment: true,
    overline: "FULL STACK • SAAS",
    title: "Slotix — Reservas",
    description: "Arquitectura multi-tenant para reservas en tiempo real.",
    image: Images.projects.KitKeeperPreview,
    features: ["PAGOS CON STRIPE", "PANEL ADMIN"],
    skills: ["Astro", "React", "Tailwind"],
    actionLinks: []
  }
];

const displayProjects = isFull ? PROJECTS : PROJECTS.slice(0, 3);
const showViewMore = !isFull && PROJECTS.length > 3;
---

<section id={Astro.props.id} class="py-24 max-w-6xl mx-auto px-6 overflow-visible">
    
    <h2 class="text-4xl md:text-5xl font-black mb-12 text-slate-900 dark:text-white tracking-tighter uppercase italic transition-colors flex items-center gap-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-cyan animate-pulse"><path d="M12 2a10 10 0 1 1 -10 10a10 10 0 0 1 10 -10zm-1 5v5l3 3l1 -1l-3 -3v-4h-1z" /></svg>
        Proyectos<span class="text-cyan">_</span>
    </h2>

    <!-- FILTROS REPARADOS: inline-flex y justify-center -->
    <div class="flex justify-center mb-16 w-full">
        <div class="inline-flex p-1.5 bg-slate-200/50 dark:bg-slate-900/50 backdrop-blur-xl border border-slate-300 dark:border-white/10 rounded-3xl shadow-xl overflow-x-auto no-scrollbar max-w-full">
            <div class="flex flex-nowrap gap-2">
                {FILTERS.map((filter, idx) => (
                    <button data-filter={filter.id} class={`project-filter-btn flex-shrink-0 flex items-center gap-3 px-6 py-2.5 rounded-2xl transition-all duration-300 cursor-pointer whitespace-nowrap ${idx === 0 ? 'bg-cyan text-white shadow-lg' : 'text-slate-500 dark:text-slate-400 hover:text-cyan'}`}>
                        <div class="w-4 h-4 flex-shrink-0"><Fragment set:html={filter.icon} /></div>
                        <span class="font-black uppercase text-[11px] md:text-xs tracking-widest">{filter.title}</span>
                    </button>
                ))}
            </div>
        </div>
    </div>

    <div id="projects-grid" class="flex flex-wrap gap-8 justify-center">
        {displayProjects.map((project) => (
            <article 
                data-category={project.category} 
                class:list={[
                    "project-card group transition-all duration-500", 
                    project.featured ? "w-full" : "w-full md:w-[calc(50%-1rem)]"
                ]}
            >
                <!-- LÓGICA DE CARD: Solo es horizontal en LG (PC) -->
                <div class:list={[
                    "relative flex flex-col overflow-hidden rounded-[2.5rem] border border-slate-200 dark:border-white/5 bg-white dark:bg-[#050b18]/60 backdrop-blur-md shadow-2xl transition-all h-full",
                    project.featured ? "lg:flex-row lg:min-h-[550px]" : "aspect-square"
                ]}>
                    
                    <!-- ZONA VISUAL (Imagen) -->
                    <div class:list={[
                        "relative overflow-hidden shrink-0 transition-all",
                        project.featured ? "lg:w-[45%] h-1/2 lg:h-auto" : "h-1/2 w-full"
                    ]}>
                        <div class="w-full h-full holographic-card relative">
                            <Picture src={project.image} alt={project.title} formats={["avif", "webp"]} widths={[400, 800]} class="object-cover w-full h-full transition duration-700 group-hover:scale-105" />
                            <div class="absolute inset-0 bg-black/20"></div>
                        </div>

                        <!-- BADGES -->
                        <div class="absolute top-4 left-4 flex flex-col gap-2 z-20">
                            {project.featured && (
                                <div class="px-3 py-1.5 rounded-full bg-amber-500/20 backdrop-blur-md border border-amber-500/40 flex items-center gap-2 text-amber-500">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 fill-current" viewBox="0 0 24 24"><path d="M12 17.75l-6.172 3.245 1.179-6.873-4.993-4.867 6.9-1.002L12 2l3.086 6.253 6.9 1.002-4.993 4.867 1.179 6.873z"/></svg>
                                    <span class="text-[8px] font-black uppercase tracking-widest">Destacado</span>
                                </div>
                            )}
                            {project.inDevelopment && (
                                <div class="px-3 py-1.5 rounded-full bg-cyan-500/20 backdrop-blur-md border border-cyan-500/40 flex items-center gap-2 text-cyan">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                                    <span class="text-[8px] font-black uppercase tracking-widest">En curso</span>
                                </div>
                            )}
                        </div>

                        <!-- Flecha Desplegable (Solo móvil y tablet) -->
                        <div class="lg:hidden absolute bottom-4 right-4 z-20 text-cyan chevron-icon transition-transform bg-black/50 rounded-full p-1.5 border border-white/10">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                        </div>
                    </div>

                    <!-- ZONA CONTENIDO -->
                    <div class:list={[
                        "flex flex-col p-6 md:p-10", 
                        project.featured ? "lg:w-[55%] justify-center" : "h-1/2 w-full justify-between"
                    ]}>
                        <div>
                            <span class="text-cyan font-mono text-[10px] tracking-[0.3em] uppercase mb-3 block">{project.overline}</span>
                            <h3 class:list={["font-black text-slate-900 dark:text-white tracking-tighter mb-4 uppercase leading-tight", project.featured ? "text-2xl md:text-3xl lg:text-5xl" : "text-xl md:text-2xl"]}>{project.title}</h3>
                            
                            <div class="mobile-content-wrapper">
                                <div class="overflow-hidden pt-4 lg:pt-0">
                                    <p class="text-slate-600 dark:text-slate-400 text-sm md:text-lg leading-relaxed mb-6 line-clamp-3 lg:line-clamp-none">{project.description}</p>
                                    <ul class="space-y-3 mb-8">
                                        {project.features.map(text => (
                                            <li class="flex items-center gap-3 text-[11px] md:text-sm font-black text-slate-700 dark:text-slate-200 uppercase tracking-widest transition-colors"><div class="w-1.5 h-1.5 rounded-full bg-cyan shadow-[0_0_8px_#00C1FD]"></div>{text}</li>
                                        ))}
                                    </ul>
                                </div>
                            </div>
                        </div>
                        <div class="mt-auto pt-6 border-t border-slate-200 dark:border-white/5 flex flex-wrap gap-2">
                            {project.skills.map(s => <span class="px-4 py-1.5 rounded-lg bg-slate-200 dark:bg-white/5 border border-slate-300 dark:border-white/10 text-[10px] font-bold text-slate-600 dark:text-cyan/80 uppercase tracking-widest">{s}</span>)}
                        </div>
                    </div>
                </div>
            </article>
        ))}
    </div>

    {showViewMore && (
        <div class="mt-20 flex justify-center">
            <a href="/all-projects" class="group btn-cyber flex items-center gap-3 px-8 py-4 rounded-2xl font-black uppercase text-sm tracking-widest text-white shadow-lg active:scale-95 transition-all">
                Ver todos los proyectos
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
            </a>
        </div>
    )}
</section>

<style>
    #projects-grid { display: flex; flex-wrap: wrap; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    .mobile-content-wrapper {
        display: grid;
        grid-template-rows: 0fr;
        opacity: 0;
        transition: grid-template-rows 0.6s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s ease;
    }

    /* SIEMPRE ABIERTO EN PC (LG) */
    @media (min-width: 1024px) {
        .mobile-content-wrapper {
            grid-template-rows: 1fr;
            opacity: 1;
        }
    }

    .project-card.is-expanded .mobile-content-wrapper { grid-template-rows: 1fr; opacity: 1; }
    .project-card.is-expanded .chevron-icon { transform: rotate(180deg); }
</style>