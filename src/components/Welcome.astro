---
import { Picture } from "astro:assets";
import { Images } from "@assets/images";

const welcomeData = {
    description: "Desarrollo aplicaciones web modernas con un enfoque en la experiencia de usuario y el rendimiento.\n\nMi pasión es crear software que no solo funcione bien, sino que también sea visualmente atractivo y fácil de usar.\n\nTrabajo con tecnologías como Astro, Laravel y React, siempre buscando expandir mis conocimientos y mejorar en cada proyecto.",
}

const typeWritingData = {
    word1 : "FullStack Developer",
    word2 : "FrontEnd Enjoyer",
    word3 : "BackEnd Enthusiast",
    word4 : "Software Architect Aspirant",
    word5 : "Coffee Lover",
}
---

<section id={`${Astro.props.id}`} class="max-w-6xl mx-auto px-6 md:px-5 pt-30 md:pt-45 pb-20 overflow-visible lg:min-h-screen">
    <div class="grid grid-cols-1 gap-12 items-center welcome-grid">
        
        <!-- Columna izquierda -->
        <div class="flex flex-col items-start order-1 lg:justify-center">
            <h2 class="text-cyan inline-block font-bold tracking-[0.2rem] md:tracking-[0.25rem] mb-6 border border-cyan/20 bg-cyan/5 px-4 py-2 rounded-full shadow-[0_0_15px_rgba(0,193,253,0.1)] whitespace-nowrap text-[10px] md:text-[1rem] lg:text-[12px] md:text-xs uppercase">
                &lt; 
                <span id="typewriter" data-words={JSON.stringify(Object.values(typeWritingData))}></span>
                <span class="typewriter-cursor">|</span>
                /&gt;
            </h2>

            <p class="text-text-muted tracking-[0.05rem] md:tracking-[0.1rem] md:text-[1.5rem] lg:text-[1rem] w-full max-w-full leading-relaxed whitespace-pre-line">Bienvenido, soy</p>
            
            <h1 class="animate-gradient-text mb-6 text-4xl md:text-6xl lg:text-8xl font-black leading-[1.1] tracking-tighter">
                Alfonso Adiego Luque
            </h1>

            <p class="text-text-muted tracking-[0.05rem] md:tracking-[0.1rem] md:text-[1.5rem] lg:text-[1rem] w-full max-w-[95%] leading-relaxed whitespace-pre-line">
                {welcomeData.description}
            </p>
        </div>
        
        <!-- Columna derecha (Para fotos o logo) -->
        <div class="flex justify-center items-center order-2 perspective-container lg:h-full lg:items-center lg:justify-center">
            <div id="logo-3d" class="relative transition-transform duration-200 ease-out floating-logo">
                <!-- halo background removed (ring will provide the glow) -->
                <div class="photo-ring rounded-full">
                    <div class="photo-content rounded-full">
                        <Picture
                            src={Images.logos.logoAlfonso}
                            alt="Logo 3D"
                            width={450}
                            height={450}
                            widths={[200, 300, 400, 600]}
                            sizes="(max-width: 768px) 128px, (max-width: 1024px) 192px, 100%"
                            formats={["avif", "webp"]}
                            loading="eager"
                            fetchpriority="high"
                            decoding="async"
                            class="welcome-photo rounded-full w-32 md:w-48 lg:w-[350px] h-auto object-contain drop-shadow-[0_20px_10px_rgba(0,0,0,0.5)]"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .perspective-container {
        perspective: 3500px;
    }

    /* Foto circular con borde animado similar a .card-border-glow */
    .photo-ring {
        position: relative;
        display: inline-block;
        border-radius: 9999px;
        padding: 2px;
        background: rgba(255, 255, 255, 0.03);
        overflow: hidden;
        transition: transform 0.3s ease;
    }

    .photo-ring::before {
        content: "";
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: conic-gradient(transparent, var(--color-cyan), var(--color-purple), transparent 30%);
        animation: rotate 4s linear infinite;
        opacity: 1;
        border-radius: 9999px;
        pointer-events: none;
        transition: opacity 0.3s ease;
        z-index: 0;
    }

    .photo-content {
        position: relative;
        z-index: 1;
        border-radius: 9999px;
        overflow: hidden;
        background: var(--bg-bottom);
    }

    .welcome-photo {
        display: block;
        border-radius: 9999px;
        position: relative;
        z-index: 2;
    }

    .welcome-grid {
        grid-template-columns: 1fr;
    }

    @media (min-width: 1024px) {
        .welcome-grid {
            grid-template-columns: 1fr auto;
        }

        /* Si la columna de la derecha no contiene imagen/picture, ocultarla */
        .perspective-container:not(:has(img)):not(:has(picture)) {
            display: none;
        }
    }

    .typewriter-cursor {
        color: var(--color-cyan);
        animation: blink 0.8s step-end infinite;
        margin-left: 4px;
        filter: drop-shadow(0 0 5px var(--color-cyan));
    }

    @keyframes blink {
        from, to { opacity: 1; }
        50% { opacity: 0; }
    }
</style>