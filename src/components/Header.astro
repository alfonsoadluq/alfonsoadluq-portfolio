---
import { Images } from "@assets/images";
import { Picture } from "astro:assets";
import ThemeButton from "./ThemeButton.astro";

const imageData = {
    src: Images.logos.logoAlfonso,
    alt: "Logo de Alfonso Adiego Luque",
};

const navData =[
    { name: "Inicio", href: "/#welcome", title: "Ir al inicio", "ariaLabel": "Ir al inicio" },
    { name: "Experiencia", href: "/#experience", title: "Ir a la experiencia", "ariaLabel": "Ir a la experiencia" },
    { name: "Proyectos", href: "/#projects", title: "Ir a los proyectos", "ariaLabel": "Ir a los proyectos" },
    { name: "Sobre mí", href: "/#about", title: "Ir a sobre mí", "ariaLabel": "Ir a sobre mí" },
    { name: "Contacto", href: "/#contact", title: "Ir al contacto", "ariaLabel": "Ir al contacto" },
]
---

<header class="fixed top-0 left-0 w-full flex justify-center items-start z-100 pt-6 pointer-events-none">
    
    <!-- Menú de navegación PC -->
    <nav id="main-nav" class="relative pointer-events-auto flex items-center justify-center w-full transition-all duration-600 ease-[cubic-bezier(0.22,1,0.36,1)] border rounded-full will-change-[max-width,background-color] origin-center max-w-175 h-18 bg-transparent border-transparent overflow-hidden">

        <div id="logo-box" class="absolute left-6 flex items-center transition-all duration-600 ease-[cubic-bezier(0.22,1,0.36,1)] z-20">
            <a href="/#welcome" class="relative cursor-pointer transition-transform active:scale-95 select-none outline-none">
                <Picture
                    id="logo-image"
                    {...imageData}
                    width={100}
                    height={80}
                    widths={[100, 120, 160, 200]}
                    sizes="(max-width: 768px) 105px, 100px"
                    formats={["avif", "webp"]}
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                    class="w-15 md:w-12.5 h-auto object-contain transition-transform duration-600"
                />
            </a>
        </div>

        <ul class="hidden md:flex items-center justify-center gap-8 z-10">
            {navData.map((item) => (
                <li class="text-sm font-medium text-text-muted transition-colors duration-300">
                    <a href={item.href} title={item.title} aria-label={item.ariaLabel} class="hover:text-cyan whitespace-nowrap">{item.name}</a>
                </li>
            ))}
        </ul>

        <div id="theme-box" class="absolute right-6 flex items-center gap-4 transition-all duration-600 ease-[cubic-bezier(0.22,1,0.36,1)] z-20">
            <div class="hidden md:block">
                <ThemeButton />
            </div>
            <button id="mobile-menu-btn" class="md:hidden p-2 text-text-muted hover:text-cyan transition-colors" aria-label="Abrir menú">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M4 6l16 0" />
                    <path d="M4 12l16 0" />
                    <path d="M4 18l16 0" />
                </svg>
            </button>
        </div>
    </nav>

    <!-- Menú Móvil preparado -->
    <div id="mobile-backdrop" class="fixed inset-0 bg-black/60 backdrop-blur-md z-150 opacity-0 pointer-events-none transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]"></div>

    <!-- Panel de navegación en móvil -->
    <aside id="mobile-sidebar" class="fixed top-0 right-0 h-screen w-70 bg-white dark:bg-[#050b18] border-l border-slate-200 dark:border-white/10 z-200 flex flex-col px-8 py-8 shadow-2xl pointer-events-auto">
        
        <div class="mobile-anim flex justify-between items-center mb-12 min-h-10" style="transition-delay: 100ms;">
            <a href="/" class="outline-none" aria-label="Logo de Alfonso Adiego Luque">
                <Picture
                {...imageData}
                width={200}
                height={160}
                widths={[100, 150, 200, 250]}
                sizes="(max-width: 768px) 45px, (max-width: 1024px) 90px, 200px"
                formats={["avif", "webp"]}
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="w-11.25 md:w-22.5 lg:w-50 h-auto object-contain drop-shadow-[0_0_8px_rgba(0,193,253,0.3)]"
                />
            </a>

            <button id="close-menu-btn" class="p-2 dark:text-text-muted hover:text-cyan transition-transform active:scale-90" aria-label="Cerrar menú">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M18 6l-12 12" />
                    <path d="M6 6l12 12" />
                </svg>
            </button>
        </div>

        <ul class="flex flex-col gap-6 w-full px-2">
            {navData.map((item, index) => (
                <li class="mobile-anim flex items-center justify-between w-full min-h-12"
                    style={`transition-delay: ${150 + index * 60}ms;`}>
                    <a href={item.href} title={item.title} aria-label={item.ariaLabel} class="mobile-link text-2xl font-bold text-slate-800 dark:text-white/90 hover:text-cyan transition-colors leading-none block">
                        {item.name}
                    </a>
                    {index === 0 && (
                        <div class="pr-1">
                            <ThemeButton />
                        </div>
                    )}
                </li>
            ))}
        </ul>
    </aside>
</header>

<style>     
    #mobile-sidebar {
        transform: translateX(120%) skewX(-8deg);
        opacity: 0;
        visibility: hidden;
        transition: transform 0.6s cubic-bezier(0.22, 1.2, 0.36, 1),
                    opacity 0.4s ease,
                    visibility 0.6s;
        will-change: transform, opacity;
    }

    #mobile-sidebar.menu-open {
        transform: translateX(0) skewX(0);
        opacity: 1;
        visibility: visible;
    }

    .mobile-anim {
        opacity: 0;
        transform: translateX(40px) scale(0.9);
        filter: blur(10px);
        transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: transform, opacity, filter;
    }

    #mobile-sidebar.menu-open .mobile-anim {
        opacity: 1;
        transform: translateX(0) scale(1);
        filter: blur(0);
    }
</style>

<script>
    const initHeader = () => {
        const nav = document.getElementById('main-nav');
        const logoImage = document.getElementById('logo-image');
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const closeMenuBtn = document.getElementById('close-menu-btn');
        const mobileSidebar = document.getElementById('mobile-sidebar');
        const mobileBackdrop = document.getElementById('mobile-backdrop');
        const mobileLinks = document.querySelectorAll('.mobile-link');

        if (!nav) return;

        const topClasses =['bg-transparent', 'border-transparent', 'h-[72px]'];
        const pillClasses =['bg-white/10', 'dark:bg-[#030712]/60', 'backdrop-blur-xl', 'border-gray-200/20', 'dark:border-white/10', 'shadow-2xl', 'h-[56px]'];

        let isScrolled = window.scrollY > 20;

        const updateUI = () => {
            requestAnimationFrame(() => {
                if (!isScrolled) {
                    nav.classList.remove('duration-[250ms]');
                    nav.classList.add('duration-[650ms]');
                    nav.classList.remove(...pillClasses, 'max-w-[680px]');
                    nav.classList.add(...topClasses, 'max-w-[700px]');
                    logoImage?.classList.remove('scale-[0.85]');
                } else {
                    nav.classList.remove('duration-[650ms]');
                    nav.classList.add('duration-[250ms]');
                    nav.classList.remove(...topClasses, 'max-w-[700px]');
                    nav.classList.add(...pillClasses, 'max-w-[680px]');
                    logoImage?.classList.add('scale-[0.85]');
                }
            });
        };

        window.addEventListener('scroll', () => {
            const shouldBeScrolled = window.scrollY > 20;
            if (shouldBeScrolled !== isScrolled) {
                isScrolled = shouldBeScrolled;
                updateUI();
            }
        });

        const openMenu = () => {
            mobileSidebar?.classList.add('menu-open');
            mobileBackdrop?.classList.add('opacity-100', 'pointer-events-auto');
            mobileBackdrop?.classList.remove('opacity-0', 'pointer-events-none');
            document.body.style.overflow = 'hidden';
        };

        const closeMenu = () => {
            mobileSidebar?.classList.remove('menu-open');
            mobileBackdrop?.classList.add('opacity-0', 'pointer-events-none');
            mobileBackdrop?.classList.remove('opacity-100', 'pointer-events-auto');
            document.body.style.overflow = '';
        };

        mobileMenuBtn?.addEventListener('click', openMenu);
        closeMenuBtn?.addEventListener('click', closeMenu);
        mobileBackdrop?.addEventListener('click', closeMenu);
        mobileLinks.forEach(link => link.addEventListener('click', closeMenu));

        updateUI();
    }

    initHeader();
    document.addEventListener('astro:page-load', initHeader);
</script>