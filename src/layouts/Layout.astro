---
import '../styles/global.css'
import '@fontsource-variable/inter/wght.css';
import '@fontsource/poppins/500.css';

import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro'

import Seo from '@components/Seo.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
---
<!doctype html>
<html lang="es-ES" class="notransition" data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<Seo title="Portfolio de Alfonso Adiego Luque - Desarrollador FullStack Junior" description="Soy Alfonso Adiego Luque, desarrollador FullStack Junior. Explora mis proyectos y descubre cómo puedo ayudarte a desarrollar tus ideas." />
		<script is:inline>
			const applyTheme = () => {
				const root = document.documentElement;
				// Disable transitions while we apply the theme to avoid flashes
				root.classList.add('notransition');

				const theme = (() => {
					if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
						return localStorage.getItem('theme');
					}
					if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
						return 'dark';
					}
					return 'light';
				})();

				root.setAttribute('data-theme', theme);
				if (theme === 'dark') {
					root.classList.add('dark');
				} else {
					root.classList.remove('dark');
				}

				// Remove the temporary no-transition class on the next paint
				requestAnimationFrame(() => {
					requestAnimationFrame(() => root.classList.remove('notransition'));
				});
			};

			applyTheme();
			document.addEventListener('astro:after-swap', applyTheme);
		</script>
		<ClientRouter />
		<Analytics/>
	</head>
	<body>
		<div id="cursor" class="cursor"></div>
		<Header />
		<slot />
		<Footer />
		<script src="../scripts/main.ts"></script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>